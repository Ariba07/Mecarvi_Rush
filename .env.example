# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your own values.
# Never commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase
# Obtain these from the Firebase console → Project settings → Your apps
FIREBASE_API_KEY_IOS=your_ios_api_key_here
FIREBASE_API_KEY_ANDROID=your_android_api_key_here
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID_IOS=1:000000000000:ios:xxxxxxxxxxxxxxxxxxxx
FIREBASE_APP_ID_ANDROID=1:000000000000:android:xxxxxxxxxxxxxxxxxxxx

# Stripe
# Publishable key only — never put the secret key in a mobile app
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# API
# Base URL of your backend REST API (include trailing slash)
API_BASE_URL=https://api.yourbackend.com/public/
